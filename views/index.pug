    script.
      //token
      const token = localStorage.getItem('token');
      if (!token) {
        alert('Debes iniciar sesión');
        window.location.href = 'login.html';
      }
      
      const usuario = JSON.parse(localStorage.getItem("usuario"));
      const saludo = document.getElementById("saludo");

      //saludar usuario
      if (usuario) {
        saludo.textContent = usuario.username.charAt(0).toUpperCase() + usuario.username.slice(1);
      }
        
      const btn = document.getElementById("btnPublicar");
      const textarea = document.getElementById("subir");
      const feed = document.getElementById("feed");
      const mensaje = document.getElementById("mensajePublicacion");
      const busqueda = document.getElementById("busqueda");
      let fotosGlobal = [];
      const resultadosBusqueda = document.getElementById("resultadosBusqueda");
      
      //buscar usuarios
      
      busqueda.addEventListener("input", async () => {

        const texto = busqueda.value;

        if (texto.length < 2) {

          resultadosBusqueda.innerHTML = "";
          
          return;
        }

        if (texto.startsWith("#")) {
          
          buscarPosts(texto);

          return;
        }

        try {

          //- const res = await fetch(
          //-   `/api/usuarios/buscar?q=${encodeURIComponent(texto)}`,
          //- );
          const res = await fetch(

         `https://fotaza-backend.onrender.com/api/usuarios/buscar?q=${encodeURIComponent(texto)}`
            );

          const usuarios = await res.json();

          resultadosBusqueda.innerHTML = "";

          usuarios.forEach(usuario => {
           
            resultadosBusqueda.innerHTML += `

              <div class="usuario-resultado">

                <span>

                  ${usuario.username}

                </span>

                <button

                  class="btn-seguir"

                  id="seguir-${usuario.id_usuario}"

                  onclick="
                    seguirUsuario(${usuario.id_usuario})
                  "
                >

                  Seguir

                </button>

              </div>
            `;
          });

          buscarPosts(texto);

        } catch (error) {

          console.error(error);
        }
      });

      async function buscarPosts(texto) {
          
        try {
          
          const res = await fetch(

            //- `/api/fotos/buscar?q=${encodeURIComponent(texto)}`,
            `https://fotaza-backend.onrender.com/api/fotos/buscar?q=${encodeURIComponent(texto)}`
            {
              headers: {
                Authorization:
                  "Bearer " + token
              }
            }
          );

          const fotos =
            await res.json();

          renderizarFotos(fotos);

        } catch (error) {

          console.error(error);
        }
      }



      //publicar
      btn.addEventListener("click", async () => {

        const archivo = document.getElementById("archivoImagen").files[0];
        const titulo =document.getElementById("titulo").value;
        const tags = document.getElementById("tags").value
        if (!archivo||!titulo) {

          mensaje.style.display = "block";
          mensaje.className = "mensaje-error";
          mensaje.textContent = "Tenés que subir una imagen y agregar un título";

          setTimeout(() => {
            mensaje.style.display = "none";
            mensaje.textContent = "";
          }, 3000);
          return;
        }
        const formData = new FormData();

        formData.append("imagen", archivo);
        formData.append("titulo", titulo);
        formData.append("descripcion", textarea.value);
        formData.append("tags",tags);
        try {

          const res = await fetch(
            //- "/api/fotos",
            `https://fotaza-backend.onrender.com/api/fotos}`,
            method: "POST",
            {
           

            headers: {
              Authorization: "Bearer " + token
            },

            body: formData
          });

          const data = await res.json();

          console.log(data);
          
          mensaje.style.display = "block";
          mensaje.className = "mensaje-ok";
          mensaje.textContent = "Publicación subida correctamente";
          textarea.value = "";
          document.getElementById("archivoImagen").value = "";
          document.getElementById("titulo").value = "";
          document.getElementById("tags").value = "";

          setTimeout(() => {
            mensaje.style.display = "none";
            mensaje.textContent = "";
          }, 3000);
          cargarMisPosts();
        

          } catch (error) {

            console.error(error);
          }
         
      });


      function renderizarFotos(fotos) {

        fotosGlobal = fotos;

        feed.innerHTML = "";
        
        fotos.forEach(foto => {

          feed.innerHTML += `
          <div class="card">

                 <div class="card-header">

                   <div class="avatar"></div>

                  <span class="username">
                    ${foto.username}
                   </span>
                 </div>

                 <div class="card-body">
                    <h2 class="titulo-post">

                       ${foto.titulo || ""}

                    </h2>
                  
                   <p>
                     ${foto.descripcion}
                   </p>
                   <p class="tags">

                    ${foto.tags || ""}

                  </p>
                     <img
                    src="/uploads/${foto.url_imagen}"
                    class="foto-feed"
                    onclick="
                        abrirPost(${foto.id_foto})
                      "
                  >

                </div>

                <select
                    id="valoracion-${foto.id_foto}"
                  >

                    <option value="1">1⭐</option>
                    <option value="2">2⭐</option>
                    <option value="3">3⭐</option>
                    <option value="4">4⭐</option>
                    <option value="5">5⭐</option>

                  </select>

                  <button
                    id="btn-valorar-${foto.id_foto}"
                    ${foto.disabled ? "disabled" : ""}
                    onclick="
                      valorarFoto(${foto.id_foto})
                    "
                  >
                    Valorar
                  </button>
                  <p class="valoracion">

                    ⭐ ${foto.promedio || 0}

                    (${foto.votos} votos)

                  </p>
                <div class="comentarios">

                <input
                   type="text"
                   placeholder="Escribí un comentario..."
                   id="comentario-${foto.id_foto}"
                 >

                <button
                  onclick="comentar(${foto.id_foto})"
                 >
                   Comentar
                 </button>

                 <div id="lista-comentarios-${foto.id_foto}">
                 </div>

               </div>

               </div>
         
            
          
          `;
        });

        fotos.forEach(foto => {

          cargarComentarios(foto.id_foto);
          
        });
      }

      async function cargarFotos() {

          try {

            const res = await fetch(
              //-  "/api/fotos"
            `https://fotaza-backend.onrender.com/api/fotos`,
              {
                headers: {
                  Authorization:
                    "Bearer " + token
                }
              }
            );

            const fotos =
              await res.json();

            renderizarFotos(fotos);

          } catch (error) {

            console.error(error);
          }
        }

      async function cargarFeedSeguidos() {

          try {

            const res = await fetch(
              //-  "/api/fotos/feed"
               `https://fotaza-backend.onrender.com/api/fotos/feed`,
              {
                headers: {
                  Authorization:
                    "Bearer " + token
                }
              }
            );

            const fotos =
              await res.json();

            renderizarFotos(fotos);

          } catch (error) {

            console.error(error);
          }
        }


      async function cargarMisPosts() {
          try {

            const res = await fetch(
              //- "/api/fotos/mias",
              `https://fotaza-backend.onrender.com/api/fotos/mias`,
              {
                headers: {
                  Authorization:
                    "Bearer " + token
                }
              }
            );

            const fotos =
              await res.json();

            renderizarFotos(fotos);

            fotos.forEach(foto => {

              const boton =
                document.getElementById(
                  `btn-valorar-${foto.id_foto}`
                );
                boton.textContent = "Es tu publicación";
                boton.disabled = true;
                
              
            });

          } catch (error) {

            console.error(error);
          }
        }
        
      async function seguirUsuario(id) {

        try {

          const res = await fetch( 
            //- "/api/seguidores",
            `https://fotaza-backend.onrender.com/api/seguidores`, {

              method: "POST",

              headers: {

                "Content-Type":
                  "application/json",

                Authorization:
                  "Bearer " + token
              },

              body: JSON.stringify({
                usuario_seguido: id
              })
            }
          );

          const data = await res.json();

          console.log(data);
          
          const boton = document.getElementById( `seguir-${id}`);

            boton.textContent = "Siguiendo";
            boton.disabled = true;
            boton.style.opacity = "0.7";

          cargarSeguidos();

        } catch (error) {

          console.error(error);
        }
      }

      async function cargarSeguidos() {

        const lista = document.getElementById("listaAmigos");

        try {

          const res = await fetch( 
            //- "/api/seguidores",
          `https://fotaza-backend.onrender.com/api/seguidores`,
            {

              headers: {
                Authorization:
                  "Bearer " + token
              }
            }
          );

          const usuarios =
            await res.json();

          lista.innerHTML = "";

          usuarios.forEach(usuario => {

            lista.innerHTML += `

              <div class="carda">

                <div class="card-header">

                  <div class="avatar"></div>

                  <span class="username">
                    ${usuario.username}
                  </span>

                </div>

              </div>
            `;
          });

        } catch (error) {

          console.error(error);
        }
      }

      async function comentar(id_foto) {
        
          const input = document.getElementById( `comentario-${id_foto}` );
          
          const contenido =
            input.value;

          if (!contenido.trim()) return;

          try {

            const res = await fetch(
              //- "/api/comentarios",
              `https://fotaza-backend.onrender.com/api/comentarios`,
              {

                method: "POST",

                headers: {

                  "Content-Type":
                    "application/json",

                  Authorization:
                    "Bearer " + token
                },

                body: JSON.stringify({

                  id_foto,
                  contenido
                })
              }
            );

            const data =
              await res.json();

           
            cargarComentarios(id_foto);
            input.value = "";

          } catch (error) {
            console.error(error);
          }
        }

      async function cargarComentarios(id_foto) {

        const div =document.getElementById(`lista-comentarios-${id_foto}` );

        try {

          const res = await fetch( 
            //- `/api/comentarios/${id_foto}`
            `https://fotaza-backend.onrender.com/api/comentarios/${id_foto}`
            );

          const comentarios = await res.json();

          div.innerHTML = "";

          comentarios.forEach(c => {

            div.innerHTML += `

              <div class="comentario">

                <strong>
                  ${c.username}
                </strong>

                ${c.contenido}

              </div>
            `;
          });

          } catch (error) {
          console.error(error);
          }
      }

      async function abrirPost(id_foto) {
        
        const modal =document.getElementById( "modalPost");

        const contenido =document.getElementById( "contenidoModal" );

        const foto =
          fotosGlobal.find(
            f => f.id_foto == id_foto
          );
        
        contenido.innerHTML = `

          <div class="post-imagen">

            <img
              src="/uploads/${foto.url_imagen}"
            >

          </div>

          <div class="modal-info">
            <div class="card">
              <div class="card-header">

                  <div class="avatar"></div>

                  <span class="username">
                    ${foto.username}
                  </span>

                </div>
        
              <div class="card-body">
                <h2 class="titulo-post">
                  ${foto.titulo || ""}
                </h2>
                <p>
                  ${foto.descripcion}
                </p>
              </div>
            </div>

            <div class="card">
              <div
                id="lista-comentario-${foto.id_foto}"
              >
            </div>
            <input
                  type="text"
                  placeholder="Escribí un comentario..."
                  id="comentarios-${foto.id_foto}"
                >

                <button
                  onclick="comentarModal(${foto.id_foto})"
                >
                  Comentar
                </button>
          </div>
              

          </div>
        `;

        modal.style.display = "flex";
        
        cargarComentariosModal(id_foto);
      }

      function cerrarPost() {
       document.getElementById("modalPost").style.display = "none";
        cargarFotos()
      }

       async function cargarComentariosModal(id_foto) {
          
        const div = document.getElementById( `lista-comentario-${id_foto}`);
        
        try {

          const res = await fetch(
            //-  `/api/comentarios/${id_foto}`
             `https://fotaza-backend.onrender.com/api/comentarios/${id_foto}`
             );
          
          const comentarios =await res.json();

          div.innerHTML = "";

          comentarios.forEach(c => {
            
            div.innerHTML += `

              <div class="comentario">

                <strong>${c.username}</strong>

                ${c.contenido}

              </div>
            `;
          });

        } catch (error) {
          console.error(error);
        }
      }

      async function comentarModal(id_foto) {
        
          const input =document.getElementById(`comentarios-${id_foto}` );
          
          const contenido = input.value;

          if (!contenido.trim()) return;

          try {

            const res = await fetch(
              //-  "/api/comentarios"
               `https://fotaza-backend.onrender.com/api/comentarios`
               ,
              {

                method: "POST",

                headers: {

                  "Content-Type":
                    "application/json",

                  Authorization:
                    "Bearer " + token
                },

                body: JSON.stringify({
                  id_foto,
                  contenido
                })
              }
            );

            const data =
              await res.json();

            
            cargarComentariosModal(id_foto);
            input.value = "";

          } catch (error) {
            console.error(error);
          }
        }
      

      async function valorarFoto(id_foto) {

        const select =
          document.getElementById(
            `valoracion-${id_foto}`
          );

        const puntuacion =
          select.value;

        try {

          const res = await fetch(
            //- "/api/valoraciones",
            `https://fotaza-backend.onrender.com/api/valoraciones`,
            {

              method: "POST",

              headers: {

                "Content-Type":
                  "application/json",

                Authorization:
                  "Bearer " + token
              },

              body: JSON.stringify({

                id_foto,
                puntuacion
              })
            }
          );

          const data =
            await res.json();

          console.log(data);
         
          select.disabled = true;

          const boton =document.getElementById(`btn-valorar-${id_foto}`);

          boton.disabled = true;

          boton.textContent ="Valorado";
          
          cargarFeedSeguidos()
        } catch (error) {

          console.error(error);
        }
        
      }
      cargarSeguidos();
      cargarMisPosts();
      