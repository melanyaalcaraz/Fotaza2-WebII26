doctype html
html
  head
    title Registro - Fotaza 
    meta(charset="UTF-8")
    link(rel="stylesheet", href="css.css")
  body
    h1 Crea tu cuenta en Fotaza!

    form(action="/api/usuarios/registro" method="POST")
      
      div
        label(for="nombre") Nombre de usuario:
        input(type="text" name="nombre" required)

      div
        label(for="email") Email:
        input(type="email" name="email" required)

      div
        label(for="password") Contraseña:
        input(type="password" name="password" required)
        
      div
        button(type="submit") Registrarse

    // 🔹 MENSAJES
    if query.ok == 1
     p(style="color:green") Usuario registrado correctamente

     script.
      setTimeout(() => {
      window.location.href = "/login";
      }, 3000);

    if query.error == 1
      p(style="color:red") El email ya está registrado

    if query.error == 2
      p(style="color:red") Todos los campos son obligatorios

    p ¿Ya estás registrado? 
      a(href="/login") Iniciá sesión